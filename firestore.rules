rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function signedInUID() {
      return request.auth.uid;
    }

    function signedInEmail() {
      return request.auth.token.email != null
        ? lower(request.auth.token.email)
        : "";
    }

    function memberDoc(orgId, memberId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(memberId));
    }

    function isOrgMember(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(signedInUID()))
        && memberDoc(orgId, signedInUID()).data.status == "active";
    }

    function currentMembership(orgId) {
      return memberDoc(orgId, signedInUID()).data;
    }

    function isOrgManager(orgId) {
      return isOrgMember(orgId)
        && currentMembership(orgId).role == "accountManager";
    }

    function canClaimInvite() {
      return isSignedIn()
        && resource != null
        && resource.data.emailAddressLower == signedInEmail()
        && resource.data.status in ["invited", "active"];
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && signedInUID() == userId;

      match /{document=**} {
        allow read, write: if isSignedIn() && signedInUID() == userId;
      }
    }

    match /organizations/{orgId} {
      allow create: if isSignedIn();
      allow read: if isOrgMember(orgId);
      allow update, delete: if isOrgManager(orgId);

      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgManager(orgId);

        allow update: if isOrgManager(orgId)
          || (
            memberId == signedInUID()
            && canClaimInvite()
            && request.resource.data.uid == signedInUID()
            && request.resource.data.emailAddressLower == resource.data.emailAddressLower
            && request.resource.data.organizationID == resource.data.organizationID
            && request.resource.data.role == resource.data.role
            && request.resource.data.permissions == resource.data.permissions
            && request.resource.data.assignedVehicleIDs == resource.data.assignedVehicleIDs
            && request.resource.data.assignedDriverID == resource.data.assignedDriverID
          );

        allow delete: if isOrgManager(orgId);
      }
    }
  }
}
